DB_TYPE=sqlite
SQLITE_PATH=./data/anime.db

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/anime_stream

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=anime_stream
DB_SYNC=true

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
